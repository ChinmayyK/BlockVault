# --- API Security ---
SECRET_KEY=replace_with_long_random_secret
JWT_SECRET=replace_with_long_random_jwt_secret
JWT_EXP_MINUTES=60

# --- CORS & Frontend ---
# Include your Vercel URL here
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://your-vm-ip,https://block-vault.vercel.app


# --- S3 / MinIO ---
S3_BUCKET=blockvault
S3_REGION=us-east-1
S3_ACCESS_KEY=replace_with_minio_access_key
S3_SECRET_KEY=replace_with_minio_secret_key

# --- Optional Blockchain Anchoring ---
ETH_RPC_URL=
ETH_PRIVATE_KEY=
FILE_REGISTRY_ADDRESS=

